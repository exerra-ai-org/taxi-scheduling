# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/taxi"
# Connection pool tuning (defaults: 20 / 20s / 30s).
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT_SECONDS=20
# DB_CONNECT_TIMEOUT_SECONDS=30

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Dev:  single origin
# Prod: add any custom domains
CORS_ORIGIN="http://localhost:5173"
# CORS_ORIGIN="https://londonlutontaxi.com,https://www.londonlutontaxi.com"

# ── Authentication ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN_SECONDS=604800   # default: 7 days

# ── App URLs ────────────────────────────────────────────────────────────────────
APP_NAME="Taxi Concierge"
# Frontend URL — used in email links (magic link, password reset, invitations).
APP_BASE_URL="http://localhost:5173"
# Backend's own public URL — used to construct uploaded-file download URLs.
APP_SELF_URL="http://localhost:3000"
# Production:
# APP_BASE_URL="https://londonlutontaxi.com"
# APP_SELF_URL="https://api.londonlutontaxi.com"

# ── Email ───────────────────────────────────────────────────────────────────────
EMAIL_FROM="London Luton Taxi <noreply@londonlutontaxi.com>"
# Option 1 — Resend (transactional email, preferred for magic links):
RESEND_API_KEY=
# Option 2 — SMTP (also used for ride-reminder / watchdog notifications):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Push Notifications (Web Push / VAPID) ──────────────────────────────────────
# Generate a key pair once: npx web-push generate-vapid-keys
# Leave blank to disable push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:ops@taxi.local"

# ── Driver Heartbeat ────────────────────────────────────────────────────────────
DRIVER_HEARTBEAT_STALE_MINUTES=5
DRIVER_HEARTBEAT_FALLBACK_WINDOWS=2

# ── Background Jobs ─────────────────────────────────────────────────────────────
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOBS_TICK_SECONDS=60
# Comma-separated minutes before ride pickup to send reminders.
RIDE_REMINDER_MINUTES=120,60,15
